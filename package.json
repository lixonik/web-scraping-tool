{
  "name": "electron-playwright",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "vite-node ./scripts/run-dev.ts",
    "angular-serve": "ng serve",
    "build:prod": "ng build",
    "build:renderer": "ng build --output-path=electron/resources",
    "build:win": "npm run build:renderer && npm --prefix electron run build:win",
    "build:mac": "npm run build:renderer && npm --prefix electron run build:mac",
    "build:linux": "npm run build:renderer && npm --prefix electron run build:linux",
    "vite": "vite",
    "test": "ng test",
    "vite-node": "vite-node"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ng-zorro-antd": "^21.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@electron-toolkit/preload": "3.0.2",
    "@playwright/test": "1.58.2",
    "@types/node": "~24.1.0",
    "@types/wait-on": "^5.0.0",
    "@vitest/browser-playwright": "4.0.18",
    "chrome-launcher": "1.2.1",
    "commander": "14.0.3",
    "driver.js": "1.4.0",
    "jsdom": "^27.1.0",
    "msw": "^2.12.10",
    "playwright": "1.58.2",
    "start-server-and-test": "2.1.3",
    "ts-essentials": "10.1.1",
    "typescript": "~5.9.2",
    "vite": "7.3.0",
    "vite-node": "5.3.0",
    "vitest": "^4.0.8",
    "wait-on": "9.0.4"
  }
}
